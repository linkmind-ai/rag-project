# Elasticsearch
ES_HOST=https://your-elasticsearch-host/
ES_INDEX=vector-test-index
ES_ID=your-elasticsearch-id
ES_API_KEY=your-elasticsearch-api-key
VEC_DIMS=1024

# Ollama
OLLAMA_HOST=https://your-ollama-host/
OLLAMA_MODEL=hf.co/LGAI-EXAONE/EXAONE-4.0-1.2B-GGUF:BF16
EMBEDDING_MODEL=bge-m3:latest

# API
API_HOST=0.0.0.0
API_PORT=8000
MAX_CONCURRENT_REQUESTS=5

# RAG Base
TOP_K_RESULTS=3
MAX_HISTORY_LENGTH=10

# PersonaRAG + Self-RAG (optional)
ROUTING_GATE_MODE=rule_llm_fallback
SELF_RAG_MAX_LOOPS=2
SELF_RAG_SEGMENT_MODE=sentence
SELF_RAG_PROFILE=balanced
MIN_UTILITY=3.5
MIN_AVG_REL=0.55
MAX_NO_SUPPORT_RATIO=0.30
MAX_PARTIAL_OR_NO_RATIO=0.55
MIN_FULL_SUPPORT_RATIO_HIGH_RISK=0.75

# Notion (optional)
NOTION_TOKEN=
NOTION_VERSION=2022-06-28
